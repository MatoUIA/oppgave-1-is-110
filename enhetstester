using System;
using System.Collections.Generic;
using System.Linq;

public class EnhetsTester
{
    public static void KjorAlleTester()
    {
        Console.Clear();
        Console.WriteLine("=== STARTER ENHETSTESTER ===");
        
        Test_SeedData_Brukere();
        Test_KursValidering_Duplikat();
        Test_BokBeholdning_Sjekk();

        Console.WriteLine("\n--- TESTER FULLFØRT ---");
        Console.WriteLine("Trykk en tast for å avslutte...");
        Console.ReadKey();
    }

    public static void Test_SeedData_Brukere()
    {
        Console.Write("Test 1 - Brukere lastet inn: ");
        if (Program.alleBrukere.Count > 0) Console.WriteLine("PASSED");
        else Console.WriteLine("FAILED");
    }

    public static void Test_KursValidering_Duplikat()
    {
        Console.Write("Test 2 - Sjekk kursduplikat: ");
        string eksisterende = "IT101";
        string ny = "IT101";
        if (eksisterende.Equals(ny, StringComparison.OrdinalIgnoreCase)) Console.WriteLine("PASSED (Logikk OK)");
        else Console.WriteLine("FAILED");
    }

    public static void Test_BokBeholdning_Sjekk()
    {
        Console.Write("Test 3 - Bibliotek beholdning: ");
        if (Program.alleBoker.Any()) Console.WriteLine("PASSED");
        else Console.WriteLine("FAILED");
    }
}
